{
  "@context": {
    "@version": 1.1,

    "pp": "https://learn.microsoft.com/en-us/rest/api/power-platform/",
    "bap": "https://learn.microsoft.com/en-us/power-platform/admin/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",

    "Environment": {
      "@id": "bap:environments-overview",
      "@type": "@id",
      "@context": {
        "id": {
          "@id": "schema:identifier"
        },
        "name": {
          "@id": "schema:identifier"
        },
        "displayName": {
          "@id": "schema:name"
        },
        "description": {
          "@id": "dcterms:description"
        },
        "location": {
          "@id": "schema:locationCreated"
        },
        "azureRegion": {
          "@id": "bap:environment/azureRegion"
        },
        "environmentSku": {
          "@id": "bap:environment/environmentSku"
        },
        "isDefault": {
          "@id": "bap:environment/isDefault",
          "@type": "xsd:boolean"
        },
        "createdTime": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        },
        "lastModifiedTime": {
          "@id": "dcterms:modified",
          "@type": "xsd:dateTime"
        },
        "provisioningState": {
          "@id": "bap:environment/provisioningState"
        },
        "creationType": {
          "@id": "bap:environment/creationType"
        },
        "databaseType": {
          "@id": "bap:environment/databaseType"
        },
        "retentionPeriod": {
          "@id": "bap:environment/retentionPeriod"
        },
        "createdBy": {
          "@id": "dcterms:creator"
        },
        "capacity": {
          "@id": "bap:environment/capacity",
          "@container": "@set"
        },
        "addons": {
          "@id": "bap:environment/addons",
          "@container": "@set"
        },
        "linkedEnvironmentMetadata": {
          "@id": "bap:environment/linkedEnvironmentMetadata"
        },
        "states": {
          "@id": "bap:environment/states"
        },
        "updateCadence": {
          "@id": "bap:environment/updateCadence"
        },
        "protectionStatus": {
          "@id": "bap:environment/protectionStatus"
        }
      }
    },

    "ApplicationPackage": {
      "@id": "pp:appmanagement/applications",
      "@type": "@id",
      "@context": {
        "id": {
          "@id": "schema:identifier"
        },
        "uniqueName": {
          "@id": "schema:alternateName"
        },
        "localizedName": {
          "@id": "schema:name"
        },
        "localizedDescription": {
          "@id": "dcterms:description"
        },
        "version": {
          "@id": "schema:softwareVersion"
        },
        "state": {
          "@id": "pp:applicationPackage/state"
        },
        "applicationVisibility": {
          "@id": "schema:accessMode"
        }
      }
    },

    "FlowRun": {
      "@id": "pp:powerautomate/flow-runs",
      "@type": "@id",
      "@context": {
        "id": {
          "@id": "schema:identifier"
        },
        "name": {
          "@id": "schema:identifier"
        },
        "startTime": {
          "@id": "schema:startDate",
          "@type": "xsd:dateTime"
        },
        "endTime": {
          "@id": "schema:endDate",
          "@type": "xsd:dateTime"
        },
        "status": {
          "@id": "pp:flowRun/status"
        },
        "trigger": {
          "@id": "pp:flowRun/trigger"
        },
        "correlation": {
          "@id": "pp:flowRun/correlation"
        }
      }
    },

    "BillingPolicy": {
      "@id": "pp:licensing/billing-policy",
      "@type": "@id",
      "@context": {
        "id": {
          "@id": "schema:identifier"
        },
        "name": {
          "@id": "schema:name"
        },
        "location": {
          "@id": "schema:locationCreated"
        },
        "status": {
          "@id": "pp:billingPolicy/status"
        },
        "billingInstrument": {
          "@id": "pp:billingPolicy/billingInstrument"
        },
        "createdBy": {
          "@id": "dcterms:creator"
        },
        "createdOn": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        },
        "lastModifiedBy": {
          "@id": "pp:billingPolicy/lastModifiedBy"
        },
        "lastModifiedOn": {
          "@id": "dcterms:modified",
          "@type": "xsd:dateTime"
        }
      }
    },

    "Principal": {
      "@id": "schema:Person",
      "@type": "@id",
      "@context": {
        "id": {
          "@id": "schema:identifier"
        },
        "displayName": {
          "@id": "schema:name"
        },
        "type": {
          "@id": "schema:additionalType"
        },
        "tenantId": {
          "@id": "bap:principal/tenantId"
        }
      }
    },

    "CapacityInfo": {
      "@id": "bap:environment/capacity",
      "@type": "@id",
      "@context": {
        "capacityType": {
          "@id": "schema:additionalType"
        },
        "actualConsumption": {
          "@id": "schema:value",
          "@type": "xsd:decimal"
        },
        "ratedConsumption": {
          "@id": "bap:capacity/ratedConsumption",
          "@type": "xsd:decimal"
        },
        "capacityUnit": {
          "@id": "schema:unitCode"
        },
        "updatedOn": {
          "@id": "dcterms:modified",
          "@type": "xsd:dateTime"
        }
      }
    },

    "LinkedEnvironmentMetadata": {
      "@id": "bap:environment/linkedEnvironmentMetadata",
      "@type": "@id",
      "@context": {
        "resourceId": {
          "@id": "schema:identifier"
        },
        "friendlyName": {
          "@id": "schema:name"
        },
        "uniqueName": {
          "@id": "schema:alternateName"
        },
        "domainName": {
          "@id": "bap:dataverse/domainName"
        },
        "version": {
          "@id": "schema:softwareVersion"
        },
        "instanceUrl": {
          "@id": "schema:url",
          "@type": "@id"
        },
        "instanceApiUrl": {
          "@id": "bap:dataverse/instanceApiUrl",
          "@type": "@id"
        },
        "baseLanguage": {
          "@id": "schema:inLanguage",
          "@type": "xsd:integer"
        },
        "instanceState": {
          "@id": "bap:dataverse/instanceState"
        },
        "createdTime": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        },
        "backgroundOperationsState": {
          "@id": "bap:dataverse/backgroundOperationsState"
        },
        "scaleGroup": {
          "@id": "bap:dataverse/scaleGroup"
        },
        "platformSku": {
          "@id": "bap:dataverse/platformSku"
        }
      }
    },

    "OperationStatus": {
      "@id": "pp:appmanagement/operations",
      "@type": "@id",
      "@context": {
        "id": {
          "@id": "schema:identifier"
        },
        "status": {
          "@id": "pp:operation/status"
        },
        "createdDateTime": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        },
        "lastActionDateTime": {
          "@id": "dcterms:modified",
          "@type": "xsd:dateTime"
        },
        "error": {
          "@id": "pp:operation/error"
        }
      }
    },

    "Connector": {
      "@id": "pp:connectors",
      "@type": "@id",
      "@context": {
        "id": {
          "@id": "schema:identifier"
        },
        "name": {
          "@id": "schema:name"
        },
        "description": {
          "@id": "dcterms:description"
        },
        "iconUri": {
          "@id": "schema:image",
          "@type": "@id"
        },
        "apiDefinitions": {
          "@id": "schema:documentation",
          "@type": "@id"
        },
        "connectionParameters": {
          "@id": "pp:connector/connectionParameters"
        },
        "tier": {
          "@id": "pp:connector/tier"
        },
        "publisher": {
          "@id": "schema:publisher"
        }
      }
    }
  }
}